{
  "name": "digital-wallet-apis",
  "version": "1.0.0",
  "description": "Mini digital wallet system API — CodeGama Node.js Developer assignment",
  "main": "./server/app.js",
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "dev": "nodemon ./server/app.js",
    "start": "npx sequelize db:migrate && npx sequelize db:seed:all && node ./server/app.js",
    "migrate": "npx sequelize db:migrate",
    "migrate:undo": "npx sequelize db:migrate:undo",
    "seed": "npx sequelize db:seed:all",
    "lint": "eslint ./server ./database"
  },
  "author": "Syed Amaan Mohammad",
  "license": "ISC",
  "dependencies": {
    "axios": "^1.18.1",
    "bcrypt": "^5.1.1",
    "cookie-parser": "^1.4.6",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "envalid": "^8.0.0",
    "express": "^4.18.2",
    "helmet": "^7.1.0",
    "ioredis": "^5.4.1",
    "jsonwebtoken": "^9.0.2",
    "morgan": "^1.10.0",
    "node-cron": "^3.0.3",
    "pg": "^8.11.5",
    "pg-hstore": "^2.3.4",
    "sequelize": "^6.37.3",
    "uuid": "^9.0.1",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "eslint": "^8.57.0",
    "nodemon": "^3.1.0",
    "sequelize-cli": "^6.6.2"
  }
}
